# ==============================================================================
# BeeBuddy Environment Variables
# ==============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is in .gitignore — never commit real credentials.
#
# Load into your shell before running:
#   set -a && source .env && set +a
#
# Or use direnv (recommended):
#   echo "dotenv" > .envrc && direnv allow
# ==============================================================================


# ==============================================================================
# API Backend (apps/api)
# ==============================================================================

# --- Application ---
DEBUG=false
# API_V1_PREFIX=/api/v1

# --- Database (PostgreSQL) ---
# Local Docker Compose default:
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/beebuddy
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=3

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Auth (JWT) — REQUIRED ---
# Generate a strong random key:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-generate-a-real-secret-key

# ACCESS_TOKEN_EXPIRE_MINUTES=30
# REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Auth Cookies (web clients) ---
# COOKIE_DOMAIN=.beebuddyai.com
# COOKIE_SECURE=true
# COOKIE_SAMESITE=lax
# COOKIE_PATH=/api

# --- OAuth2 Social Login ---
# Google (https://console.cloud.google.com/apis/credentials)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Apple (https://developer.apple.com/account/resources/identifiers)
# APPLE_CLIENT_ID=
# APPLE_WEB_CLIENT_ID=
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY=

# Microsoft (https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps)
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=

# --- S3-Compatible Storage ---
# MinIO local dev defaults (from docker-compose):
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
# S3_BUCKET=beebuddy-photos
# S3_ENDPOINT_URL=http://localhost:9000
# S3_REGION=atl1
# S3_PUBLIC_URL=http://localhost:9000
# PRESIGNED_URL_TTL_SECONDS=300

# --- Email (SendGrid) ---
# EMAIL_FROM_ADDRESS=noreply@beebuddy.app
# EMAIL_FROM_NAME=BeeBuddy
EMAIL_SUPPRESS=true                              # Set true for dev (logs email instead of sending)
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Frontend URL (used in email links) ---
FRONTEND_URL=http://localhost:8081

# --- LLM Configuration ---
LLM_PROVIDER=ollama                               # ollama | openai | anthropic | huggingface | bedrock
LLM_MODEL=beebuddy-bee                            # Primary model name (fine-tuned beekeeping model)
# LLM_MODEL_FALLBACK=llama3.2:3b                  # Fallback if primary unavailable
# OLLAMA_BASE_URL=http://localhost:11434

# --- Tool-Calling LLM (optional — defaults to primary LLM) ---
# Use a separate model for data-query tool dispatch (e.g. Claude Haiku for reliability).
# beebuddy-bee handles conversational chat; Claude Haiku handles structured tool calls.
# LLM_TOOL_PROVIDER=anthropic                     # ollama | openai | anthropic | huggingface
# LLM_TOOL_MODEL=claude-haiku-4-5-20251001        # Model name
# LLM_TOOL_BASE_URL_OVERRIDE=                     # Any OpenAI-compatible endpoint URL
# LLM_TOOL_API_KEY_OVERRIDE=                      # API key for the override URL

# --- Hugging Face Inference Endpoint (scale-to-zero GPU) ---
# For production: deploy beebuddy-bee GGUF via HF Inference Endpoints.
# 1. Create endpoint at https://ui.endpoints.huggingface.co from jsrobinson3/beebuddy-gguf
# 2. Set min replicas to 0 for scale-to-zero (saves cost when idle)
# 3. Set LLM_PROVIDER=huggingface and fill in the URL below
# HF_INFERENCE_ENDPOINT_URL=https://<id>.endpoints.huggingface.cloud

# --- Sentry (error monitoring) ---
# SENTRY_DSN=https://xxxxx@xxxxx.ingest.us.sentry.io/xxxxx
# SENTRY_TRACES_SAMPLE_RATE=0.2
# SENTRY_ENVIRONMENT=development

# --- Rate Limiting ---
# RATE_LIMIT_ENABLED=true

# --- CORS ---
# CORS_ORIGINS=["http://localhost:3000","http://localhost:8081","http://localhost:19006"]

# --- SSL Certificates (managed DB/Redis with custom CA) ---
# REDIS_CA_CERT=/path/to/ca-certificate.crt
# DATABASE_CA_CERT=/path/to/ca-certificate.crt


# ==============================================================================
# Training Pipeline (training/)
# ==============================================================================

# --- LLM API Keys (required for Stage 2 synthetic Q&A generation) ---
# Pick ONE provider. Defaults to Anthropic.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Uncomment to use OpenAI instead of Anthropic for Stage 2:
# SYNTH_PROVIDER=openai

# Override the generation model (optional):
# SYNTH_MODEL=claude-sonnet-4-20250514             # Anthropic default
# SYNTH_MODEL=gpt-4.1-mini                         # OpenAI default

# --- HuggingFace Hub ---
# Required for: --push-to-hub, cloud training (HF Jobs), gated dataset access
# Get a token with WRITE access: https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- USDA NASS API (optional) ---
# Adds US honey production/colony statistics to training data.
# Free key: https://quickstats.nass.usda.gov/api -> "Request API Key"
# USDA_NASS_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
