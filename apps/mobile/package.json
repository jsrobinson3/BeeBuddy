    "@sentry/react-native": "~7.11.0",
    "@tanstack/react-query": "^5.91.2",
    "babel-preset-expo": "^55.0.11",
    "expo": "~56.0.3",
    "expo-apple-authentication": "~56.0.4",
    "expo-build-properties": "~56.0.13",
    "expo-constants": "^56.0.14",
