{
  "name": "beebuddy-mobile",
  "version": "0.1.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:wsl": "ANDROID_HOME=$HOME/Android/sdk REACT_NATIVE_PACKAGER_HOSTNAME=$(hostname -I | awk '{print $1}') expo start --offline",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "web:wsl": "REACT_NATIVE_PACKAGER_HOSTNAME=$(ip route show | grep -i default | awk '{print $3}') expo start --web",
    "test": "jest",
    "postinstall": "patch-package"
  },
  "dependencies": {
